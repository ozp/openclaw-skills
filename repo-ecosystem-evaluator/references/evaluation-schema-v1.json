{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Repository Ecosystem Evaluation Schema v2.0",
  "description": "Structured output schema for repository architecture, semantic, and stack evaluation",
  "type": "object",
  "required": ["repository", "summary", "architecture", "quality", "semantic", "stack", "risks"],
  "properties": {
    "repository": {
      "type": "object",
      "required": ["path", "analyzed_at"],
      "properties": {
        "path": { "type": "string" },
        "analyzed_at": { "type": "string", "format": "date-time" },
        "commit_hash": { "type": ["string", "null"] }
      }
    },
    "summary": {
      "type": "object",
      "required": ["overall_score", "consistency_score", "maintainability_index", "semantic_score", "stack_fit_score", "recommendation"],
      "properties": {
        "overall_score": { "type": "number", "minimum": 0, "maximum": 10 },
        "consistency_score": { "type": "number", "minimum": 0, "maximum": 10 },
        "maintainability_index": { "type": "number", "minimum": 0, "maximum": 100 },
        "semantic_score": { "type": "number", "minimum": 0, "maximum": 10 },
        "stack_fit_score": { "type": "number", "minimum": 0, "maximum": 10 },
        "recommendation": { "type": "string", "enum": ["adopt", "evaluate", "avoid"] }
      }
    },
    "architecture": {
      "type": "object",
      "required": ["detected_pattern", "confidence"],
      "properties": {
        "detected_pattern": {
          "type": "string",
          "enum": ["layered", "hexagonal", "microservices", "monolith", "indeterminate"]
        },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "layers_detected": { "type": "array", "items": { "type": "string" } },
        "violations": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string" },
              "location": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        }
      }
    },
    "quality": {
      "type": "object",
      "required": ["maintainability_index", "consistency_score", "error_handling", "state_management", "coupling_cohesion", "testability"],
      "properties": {
        "maintainability_index": { "type": "number", "minimum": 0, "maximum": 100 },
        "comment_ratio": { "type": "number" },
        "cyclomatic_proxy": { "type": "number" },
        "architectural_conformance_score": { "type": "number", "minimum": 0, "maximum": 10 },
        "consistency_score": { "type": "number", "minimum": 0, "maximum": 10 },
        "error_handling": { "type": "object" },
        "state_management": { "type": "object" },
        "coupling_cohesion": { "type": "object" },
        "testability": { "type": "object" },
        "iso_25010_alignment": { "type": "object" }
      }
    },
    "semantic": {
      "type": "object",
      "required": ["semantic_score", "method", "dimensions"],
      "properties": {
        "semantic_score": { "type": "number", "minimum": 0, "maximum": 10 },
        "method": { "type": "string" },
        "dimensions": {
          "type": "object",
          "properties": {
            "domain_centralization": { "type": "number", "minimum": 0, "maximum": 10 },
            "invariant_visibility": { "type": "number", "minimum": 0, "maximum": 10 },
            "contract_explicitness": { "type": "number", "minimum": 0, "maximum": 10 },
            "boundary_discipline": { "type": "number", "minimum": 0, "maximum": 10 },
            "naming_coherence": { "type": "number", "minimum": 0, "maximum": 10 }
          }
        },
        "entities": { "type": "array", "items": { "type": "object" } },
        "use_cases": { "type": "array", "items": { "type": "object" } },
        "invariants": { "type": "array", "items": { "type": "object" } },
        "contracts": { "type": "array", "items": { "type": "object" } },
        "critical_flows": { "type": "array", "items": { "type": "object" } },
        "semantic_risks": { "type": "array", "items": { "type": "string" } }
      }
    },
    "stack": {
      "type": "object",
      "required": ["environment_target", "scenario_fit", "stack_fit_score"],
      "properties": {
        "environment_target": {
          "type": "string",
          "enum": ["cloud_serverless", "edge_device", "local_dev", "enterprise_k8s", "undefined"]
        },
        "stack": { "type": "object" },
        "scenario_fit": { "type": "object" },
        "operational_surface": { "type": "number" },
        "local_dev_friction": { "type": "number" },
        "deployability": { "type": "number" },
        "portability": { "type": "number" },
        "observability": { "type": "number" },
        "stack_fit_score": { "type": "number", "minimum": 0, "maximum": 10 },
        "atam_lite": { "type": "object" }
      }
    },
    "risks": {
      "type": "object",
      "properties": {
        "logic_defects": { "type": "array", "items": { "type": "object" } },
        "operational": { "type": "array", "items": { "type": "string" } },
        "maintenance": { "type": "array", "items": { "type": "string" } }
      }
    },
    "evidence": {
      "type": "object",
      "properties": {
        "coverage_pct": { "type": "number" },
        "sources": { "type": "array", "items": { "type": "object" } }
      }
    }
  }
}
